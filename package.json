{
  "name": "tag-util",
  "version": "1.3.3",
  "description": "Functional FLAC metadata editor with Svelte 5 TagState",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "super-kato",
  "license": "MIT",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts,.svelte --fix",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run typecheck && electron-vite build",
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "out": "electron-builder",
    "release": "pnpm build && pnpm out --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "electron-log": "^5.0.3",
    "electron-updater": "^6.1.7",
    "flac-tagger": "^1.1.2",
    "music-metadata": "^7.14.0",
    "svelte": "^5.0.0-next.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^1.0.2",
    "@electron-toolkit/eslint-config-ts": "^1.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@sveltejs/vite-plugin-svelte": "^3.0.2",
    "@types/node": "^18.19.8",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-svelte": "^2.35.1",
    "prettier": "^3.2.4",
    "prettier-plugin-svelte": "^3.1.2",
    "svelte-check": "^3.6.3",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^1.2.1"
  }
}
