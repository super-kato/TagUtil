{
  "name": "tag-util",
  "version": "1.4.5",
  "description": "Functional FLAC metadata editor with Svelte 5 TagState",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "super-kato",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/super-kato/TagUtil.git"
  },
  "bugs": {
    "url": "https://github.com/super-kato/TagUtil/issues"
  },
  "homepage": "https://github.com/super-kato/TagUtil#readme",
  "keywords": [
    "electron",
    "svelte",
    "flac",
    "metadata",
    "editor"
  ],
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "format": "prettier --plugin prettier-plugin-svelte --write .",
    "format:check": "prettier --plugin prettier-plugin-svelte --check .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "svelte-check": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "pnpm svelte-check && pnpm typecheck:node",
    "start": "electron-vite preview",
    "dev": "pnpm generate-licenses && electron-vite dev",
    "build": "pnpm generate-licenses && pnpm typecheck && electron-vite build",
    "generate-licenses": "node --experimental-strip-types scripts/generate-licenses.ts",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm build && dotenv -- electron-builder --dir",
    "build:win": "pnpm build && electron-builder --win --publish never",
    "build:mac": "pnpm build && electron-builder --mac --publish never",
    "sign": "dotenv -- pnpm build:mac",
    "test": "vitest run --coverage",
    "release": "pnpm version patch && git push origin main --follow-tags"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@lucide/svelte": "^1.11.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "fast-equals": "^6.0.0",
    "flac-tagger": "^2.0.0",
    "music-metadata": "^11.12.3",
    "p-limit": "^7.3.0",
    "svelte": "^5.55.5"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv-cli": "^11.0.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.17.1",
    "jsdom": "^29.1.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte-check": "^4.3.4",
    "typescript": "^6.0.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.5"
  }
}
