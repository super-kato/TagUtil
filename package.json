{
  "name": "tag-util",
  "version": "1.1.6",
  "description": "Functional FLAC metadata editor with Svelte 5 TagState",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "super-kato",
  "license": "MIT",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck": "tsc --noEmit -p src/main/tsconfig.json && tsc --noEmit -p src/renderer/tsconfig.json",
    "test": "vitest run --coverage",
    "build": "pnpm lint && pnpm typecheck && pnpm build:electron",
    "build:electron": "electron-vite build",
    "dev": "electron-vite dev",
    "preview": "electron-vite preview",
    "pack": "electron-vite build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@lucide/svelte": "^0.453.0",
    "flac-tagger": "^1.1.2",
    "music-metadata": "^10.4.0",
    "svelte-persisted-store": "^0.11.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0-next.6",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^20.14.8",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "@vitest/coverage-v8": "^2.1.3",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-svelte": "^2.46.0",
    "prettier": "^3.3.2",
    "prettier-plugin-svelte": "^3.2.8",
    "svelte": "^5.1.4",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vitest": "^2.1.3"
  }
}
