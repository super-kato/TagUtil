{
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "svelte.enable-ts-plugin": true,
  "eslint.validate": ["javascript", "javascriptreact", "svelte", "typescript"],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always",
    "source.organizeImports": "always"
  },
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#decd5b",
    "activityBar.background": "#decd5b",
    "activityBar.foreground": "#15202b",
    "activityBarBadge.background": "#209f8f",
    "activityBarBadge.foreground": "#e7e7e7",
    "activityBar.inactiveForeground": "#15202b99",
    "commandCenter.border": "#15202b99",
    "sash.hoverBorder": "#decd5b",
    "statusBar.background": "#d6c030",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#b09d23",
    "statusBarItem.remoteBackground": "#d6c030",
    "statusBarItem.remoteForeground": "#15202b",
    "titleBar.activeBackground": "#d6c030",
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveBackground": "#d6c03099",
    "titleBar.inactiveForeground": "#15202b99"
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "package.json": "pnpm-lock.yaml, pnpm-workspace.yaml, .npmrc",
    "tsconfig.json": "tsconfig.*.json, tsconfig.*.tsbuildinfo",
    "eslint.config.*": ".eslint*, .prettierignore, .prettierrc.yaml",
    ".gitignore": ".gitattributes",
    "electron.vite.config.ts": "vitest.config.ts"
  }
}
