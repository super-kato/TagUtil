{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": ["electron.vite.config.*", "src/main/**/*", "src/preload/**/*", "src/domain/**/*", "src/shared/**/*"],
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@domain/*": ["./src/domain/*"],
      "@services/*": ["./src/main/services/*"],
      "@main/*": ["./src/main/*"],
      "@resources/*": ["./resources/*"],
      "@root/*": ["./*"]
    },
    "types": ["electron-vite/node"]
  }
}
